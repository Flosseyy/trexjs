{
  "name": "trexjs",
  "version": "2.0.0",
  "description": "A feature-complete Discord bot framework with auto-discovery, TypeScript support, slash commands, voice, preconditions, cooldowns, and a no-code rule engine.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./plugins/moderation": "./plugins/moderation.js",
    "./plugins/voice": "./plugins/voice.js",
    "./persistence/mongo": "./src/persistence/MongoStorage.js"
  },
  "bin": {
    "trex": "./cli/index.js"
  },
  "files": [
    "src/",
    "cli/",
    "plugins/",
    "types/",
    "template-js/",
    "template-ts/",
    "README.md"
  ],
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/voice": "^0.17.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "inquirer": "^9.2.12",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["discord", "bot", "framework", "trex", "typescript", "slash-commands"],
  "license": "MIT"
}
